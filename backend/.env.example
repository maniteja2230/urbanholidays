# ═══════════════════════════════════════════════
#  URBAN HOLIDAYS — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git!
# ═══════════════════════════════════════════════

# Server
PORT=3000

# Gmail for sending enquiry notifications
# Use a Gmail App Password (not your regular password)
# Go to: Google Account → Security → App Passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Where to receive enquiry emails
OWNER_EMAIL=urbanholidays@gmail.com

# Your business phone (for WhatsApp links & email)
PHONE=+91 XXXXX XXXXX

# Admin key to view enquiries at /api/enquiries?key=...
# Change this to something random and secret!
ADMIN_KEY=change-this-to-a-secret-key-123

# Optional: MongoDB URI (if you upgrade from JSON file storage)
# MONGODB_URI=mongodb+srv://...
